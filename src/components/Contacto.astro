---
import Clock from "../../public/icons/Clock.astro";
import Mail from "../../public/icons/Mail.astro";
import Phone from "../../public/icons/Phone.astro";
import MapPin from "../../public/icons/MapPin.astro";
---

<section id="contacto" class="py-24 bg-white relative">
  <div class="container px-6 mx-auto">
    <div class="max-w-4xl mx-auto text-center mb-20">
      <div
        class="inline-block px-4 py-1 bg-dark text-primary text-[10px] font-black uppercase tracking-[0.3em] mb-4"
      >
        Canales de Atención
      </div>
      <h2
        class="font-display text-4xl md:text-5xl font-black text-dark uppercase tracking-tighter mb-6"
      >
        Hagamos Realidad <span class="text-primary italic">tu Proyecto</span>
      </h2>
      <p class="text-lg text-steel max-w-2xl mx-auto leading-relaxed">
        Atendemos proyectos en La Fortuna, San Carlos y zona norte de Costa Rica.
        Escribinos y te asesoramos sin ningún compromiso.
      </p>
    </div>

    <!-- WhatsApp-first block -->
    <div class="max-w-2xl mx-auto mb-12">
      <div class="bg-primary p-8 flex flex-col sm:flex-row items-center justify-between gap-6 shadow-xl">
        <div class="text-center sm:text-left">
          <div class="text-[10px] font-black uppercase tracking-[0.3em] text-dark/60 mb-2">
            Respuesta inmediata
          </div>
          <h3 class="font-display text-2xl font-black text-dark uppercase tracking-tighter leading-tight">
            ¿Preferís hablar directo?
          </h3>
          <p class="text-dark/70 text-sm mt-2 leading-relaxed">
            Escribinos por WhatsApp y te respondemos en minutos con información y precios para tu cabaña.
          </p>
        </div>
        <a
          href="https://wa.me/50684291847?text=Hola%2C+me+gustar%C3%ADa+cotizar+una+caba%C3%B1a+tur%C3%ADstica+en+La+Fortuna"
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 flex items-center gap-3 bg-[#25D366] text-white font-black uppercase tracking-widest text-xs px-8 py-4 hover:brightness-110 transition-all shadow-lg active:scale-95 whitespace-nowrap"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          💬 Escribinos por WhatsApp
        </a>
      </div>
      <div class="text-center mt-4">
        <span class="text-steel text-xs font-bold uppercase tracking-widest">o completá el formulario abajo</span>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
      <!-- Contact Form -->
      <div
        class="bg-white p-10 shadow-2xl border-t-8 border-primary relative group"
      >
        <div
          class="absolute top-0 right-0 w-24 h-24 bg-dark/5 -z-0 pointer-events-none"
        >
        </div>
        <h3 class="font-display text-2xl font-black text-dark uppercase tracking-tight mb-8">
          Cotizá tu Proyecto
        </h3>

        <form id="contactForm" class="space-y-6 relative z-10">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label
                for="name"
                class="text-[10px] font-black uppercase tracking-widest text-steel block"
                >Nombre Completo</label
              >
              <input
                id="name"
                name="name"
                type="text"
                required
                class="w-full bg-gray-50 border-2 border-gray-100 focus:border-primary focus:bg-white p-4 outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all font-bold text-dark"
              />
            </div>
            <div class="space-y-2">
              <label
                for="email"
                class="text-[10px] font-black uppercase tracking-widest text-steel block"
                >Correo Electrónico</label
              >
              <input
                id="email"
                name="email"
                type="email"
                required
                class="w-full bg-gray-50 border-2 border-gray-100 focus:border-primary focus:bg-white p-4 outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all font-bold text-dark"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label
                for="phone"
                class="text-[10px] font-black uppercase tracking-widest text-steel block"
                >Teléfono / WhatsApp <span class="text-steel/60 normal-case font-bold">(opcional)</span></label
              >
              <input
                id="phone"
                name="phone"
                type="tel"
                class="w-full bg-gray-50 border-2 border-gray-100 focus:border-primary focus:bg-white p-4 outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all font-bold text-dark"
                placeholder="+506 XXXX XXXX"
              />
            </div>
            <div class="space-y-2">
              <label
                for="subject"
                class="text-[10px] font-black uppercase tracking-widest text-steel block"
                >Tipo de Proyecto</label
              >
              <input
                id="subject"
                name="subject"
                type="text"
                required
                class="w-full bg-gray-50 border-2 border-gray-100 focus:border-primary focus:bg-white p-4 outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all font-bold text-dark"
                placeholder="Ej: Casa en La Fortuna, Consultoría"
              />
            </div>
          </div>

          <div class="space-y-2">
            <label
              for="message"
              class="text-[10px] font-black uppercase tracking-widest text-steel block"
              >Descripción del Requerimiento</label
            >
            <textarea
              id="message"
              name="message"
              required
              class="w-full min-h-[150px] bg-gray-50 border-2 border-gray-100 focus:border-primary focus:bg-white p-4 outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all font-bold text-dark"
            ></textarea>
          </div>

          <!-- Honeypot: oculto para bots, ignorado en backend -->
          <div class="hidden" aria-hidden="true">
            <input name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <div id="form-status" role="status" aria-live="polite" class="hidden"></div>

          <button
            type="submit"
            class="w-full bg-dark text-primary font-black uppercase tracking-[0.2em] text-xs py-5 shadow-xl hover:bg-primary hover:text-dark transition-all transform active:scale-[0.98]"
          >
            Enviar Solicitud &rarr;
          </button>
        </form>
      </div>

      <!-- Contact Info -->
      <div
        class="bg-dark text-white p-10 lg:p-16 flex flex-col justify-between shadow-2xl relative overflow-hidden"
      >
        <!-- Industrial accents -->
        <div
          class="absolute top-0 right-0 w-32 h-32 border-r-8 border-t-8 border-primary/20 pointer-events-none"
        >
        </div>
        <div
          class="absolute bottom-0 left-0 w-32 h-32 border-l-8 border-b-8 border-primary/20 pointer-events-none"
        >
        </div>

        <div class="relative z-10">
          <h3 class="font-display text-3xl font-black uppercase tracking-tighter mb-12">
            Contacto <span class="text-primary italic">Directo</span>
          </h3>

          <div class="space-y-10">
            {
              [
                {
                  label: "Ubicación",
                  val: "La Fortuna, San Carlos, Costa Rica",
                  sub: "Zona Norte",
                },
                {
                  label: "Teléfono",
                  val: "+506 8429 1847",
                  sub: "WhatsApp Disponible",
                },
                {
                  label: "Email",
                  val: "info@construhomescr.com",
                  sub: "Respuesta en menos de 24h",
                },
                {
                  label: "Horario",
                  val: "Lun - Vie: 9:00 AM - 6:00 PM",
                  sub: "Sábados: Previa Cita",
                },
              ].map((info) => (
                <div class="group h-min flex flex-col">
                  <span class="text-primary font-black uppercase text-[10px] tracking-[0.3em] mb-1">
                    {info.label}
                  </span>
                  <span class="text-xl font-bold text-white group-hover:text-primary transition-colors">
                    {info.val}
                  </span>
                  <span class="text-xs text-gray-500 font-bold uppercase tracking-widest mt-1">
                    {info.sub}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="mt-16 pt-8 border-t border-white/10 flex items-center justify-between relative z-10"
        >
          <span
            class="text-[10px] font-black uppercase tracking-widest text-primary italic"
            >ConstruHomesCR © 2026</span
          >
          <div class="flex gap-4">
            <!-- Social placeholders if any -->
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const showStatus = (el: HTMLElement, msg: string, isError: boolean) => {
    el.textContent = msg;
    el.className = isError
      ? "mt-2 p-4 border-l-4 border-red-500 bg-red-50 text-red-800 font-bold text-sm uppercase tracking-wide"
      : "mt-2 p-4 border-l-4 border-primary bg-primary/10 text-dark font-bold text-sm uppercase tracking-wide";
  };

  const handleContact = async (event: SubmitEvent) => {
    event.preventDefault();
    const form = event.target as HTMLFormElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const statusEl = document.getElementById("form-status") as HTMLElement;

    const originalText = submitBtn.innerText;
    submitBtn.innerText = "PROCESANDO...";
    submitBtn.disabled = true;
    statusEl.className = "hidden";

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("/api/sendEmail", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        form.reset();
        showStatus(statusEl, "¡Solicitud enviada! Nos comunicamos pronto.", false);
      } else {
        showStatus(statusEl, "Error al enviar. Escribinos por WhatsApp.", true);
      }
    } catch {
      showStatus(statusEl, "Error de conexión. Escribinos por WhatsApp.", true);
    } finally {
      submitBtn.innerText = originalText;
      submitBtn.disabled = false;
    }
  };

  document.getElementById("contactForm")?.addEventListener("submit", handleContact);
</script>
