---

const navLinks = [
  { label: "Diseños", href: "/#disenos" },
  { label: "Galería", href: "/#galeria" },
  { label: "Blog", href: "/blog/" },
  { label: "Contacto", href: "/#contacto" },
];

const year = new Date().getFullYear();

const ticker = Array(2).fill(
  "La Fortuna · San Carlos · Zona Norte · Construcción Residencial · Vivienda de Calidad"
).join(" · ");
---

<footer class="bg-dark relative overflow-hidden">

  <!-- Diagonal top border accent -->
  <div class="w-full h-2 bg-primary"></div>

  <!-- Scrolling Marquee Strip -->
  <div class="bg-primary overflow-hidden py-3 select-none">
    <div class="marquee-track flex gap-0 whitespace-nowrap">
      <span class="marquee-content text-dark font-black uppercase text-xs tracking-[0.25em] pr-16">
        {ticker}
      </span>
      <span class="marquee-content text-dark font-black uppercase text-xs tracking-[0.25em] pr-16" aria-hidden="true">
        {ticker}
      </span>
    </div>
  </div>

  <!-- Main Footer Body -->
  <div class="container mx-auto px-6 pt-20 pb-10 relative z-10">

    <!-- Top grid: wordmark + columns -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 mb-20">

      <!-- Wordmark + tagline -->
      <div class="lg:col-span-5 flex flex-col justify-between gap-10">
        <div>
          <!-- Logo -->
          <a href="/" class="inline-flex mb-8 hover:opacity-90 transition-opacity group-hover:scale-105">
            <img
              src="/icons/Nuevos/logo-primary-light.svg"
              alt="ConstruHomesCR"
              class="h-12 w-auto"
              loading="lazy"
              width="480"
              height="96"
            />
          </a>

          <!-- Large statement -->
          <p class="font-display text-4xl md:text-5xl font-black text-white uppercase tracking-tighter leading-[0.95] mb-6">
            Tu casa en<br />
            <span class="text-primary italic">La Fortuna,</span><br />
            hecha realidad.
          </p>

          <p class="text-steel text-sm leading-relaxed max-w-xs">
            Construcción residencial de calidad en La Fortuna de San Carlos y toda la Zona Norte de Costa Rica.
          </p>
        </div>

        <!-- WhatsApp CTA -->
        <a
          href="https://wa.me/50684291847?text=Hola%2C%20me%20interesa%20información%20sobre%20construcción%20en%20La%20Fortuna"
          target="_blank"
          rel="noopener noreferrer"
          class="wha-btn group inline-flex items-center gap-4 bg-primary text-dark px-8 py-5 font-black uppercase tracking-widest text-sm w-fit hover:bg-white transition-all shadow-xl active:scale-95 relative overflow-hidden"
        >
          <!-- WhatsApp icon -->
          <svg
            class="w-5 h-5 flex-shrink-0 transition-transform group-hover:scale-110"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Escribinos por WhatsApp
          <span class="ml-1 transition-transform group-hover:translate-x-1 inline-block">&rarr;</span>
        </a>
      </div>

      <!-- Spacer on large screens -->
      <div class="hidden lg:block lg:col-span-1"></div>

      <!-- Nav links -->
      <div class="lg:col-span-2">
        <h4 class="text-primary font-black uppercase text-[10px] tracking-[0.35em] mb-8 pb-3 border-b border-white/10">
          Navegación
        </h4>
        <ul class="space-y-4">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/60 hover:text-primary font-bold uppercase text-sm tracking-wider transition-colors group flex items-center gap-2"
              >
                <span class="w-4 h-px bg-primary/40 group-hover:w-6 group-hover:bg-primary transition-all inline-block"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact info -->
      <div class="lg:col-span-4">
        <h4 class="text-primary font-black uppercase text-[10px] tracking-[0.35em] mb-8 pb-3 border-b border-white/10">
          Contacto
        </h4>
        <ul class="space-y-6">
          <li>
            <a
              href="https://wa.me/50684291847"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-start gap-4 hover:text-primary transition-colors"
            >
              <div class="mt-1 w-8 h-8 bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary group-hover:border-primary transition-all">
                <svg class="w-3.5 h-3.5 text-primary group-hover:text-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <span class="block text-[10px] font-black uppercase tracking-[0.25em] text-primary/70 mb-1">Teléfono / WhatsApp</span>
                <span class="text-white font-bold group-hover:text-primary transition-colors">+506 8429 1847</span>
              </div>
            </a>
          </li>

          <li>
            <a
              href="mailto:info@construhomescr.com"
              class="group flex items-start gap-4 hover:text-primary transition-colors"
            >
              <div class="mt-1 w-8 h-8 bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary group-hover:border-primary transition-all">
                <svg class="w-3.5 h-3.5 text-primary group-hover:text-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <span class="block text-[10px] font-black uppercase tracking-[0.25em] text-primary/70 mb-1">Correo</span>
                <span class="text-white font-bold group-hover:text-primary transition-colors">info@construhomescr.com</span>
              </div>
            </a>
          </li>

          <li class="flex items-start gap-4">
            <div class="mt-1 w-8 h-8 bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <span class="block text-[10px] font-black uppercase tracking-[0.25em] text-primary/70 mb-1">Zona de Atención</span>
              <span class="text-white font-bold">La Fortuna, San Carlos</span>
              <span class="block text-steel text-xs font-bold uppercase tracking-wider mt-1">y alrededores · Zona Norte CR</span>
            </div>
          </li>

          <li class="flex items-start gap-4">
            <div class="mt-1 w-8 h-8 bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <span class="block text-[10px] font-black uppercase tracking-[0.25em] text-primary/70 mb-1">Horario</span>
              <span class="text-white font-bold">Lun – Vie: 9:00 AM – 6:00 PM</span>
              <span class="block text-steel text-xs font-bold uppercase tracking-wider mt-1">Sábados: Previa Cita</span>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-[10px] font-black uppercase tracking-[0.25em] text-primary/60 italic">
        ConstruHomesCR &copy; {year} — La Fortuna, San Carlos, Costa Rica
      </span>
      <!-- Redes sociales — reemplazar href con URLs reales cuando estén creadas -->
      <div class="flex items-center gap-3">
        <a
          href="https://www.instagram.com/construhomes_cr/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram de ConstruHomesCR"
          class="w-8 h-8 bg-white/5 border border-white/10 flex items-center justify-center hover:bg-primary hover:border-primary group transition-all"
        >
          <svg class="w-3.5 h-3.5 text-white/40 group-hover:text-dark transition-colors" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/construhomescr"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook de ConstruHomesCR"
          class="w-8 h-8 bg-white/5 border border-white/10 flex items-center justify-center hover:bg-primary hover:border-primary group transition-all"
        >
          <svg class="w-3.5 h-3.5 text-white/40 group-hover:text-dark transition-colors" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Oversized background wordmark -->
  <div
    class="absolute bottom-0 left-0 right-0 flex items-end justify-center pointer-events-none overflow-hidden select-none"
    aria-hidden="true"
  >
    <span class="text-[clamp(4rem,15vw,14rem)] font-black uppercase tracking-tighter text-white/[0.03] leading-none whitespace-nowrap pb-0">
      CONSTRU<span style="color: rgba(253,184,19,0.04)">HOMES</span>CR
    </span>
  </div>

</footer>

<style>
  .marquee-track {
    animation: marquee-scroll 35s linear infinite;
    width: max-content;
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
