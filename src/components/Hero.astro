---
import { Image } from "astro:assets";
import heroImg from "../assets/images/hero.jpg";
---

<section
  id="home"
  class="relative min-h-screen flex items-center overflow-hidden bg-white pt-20"
>
  <!-- Background Accent -->
  <div
    class="absolute top-0 right-0 w-1/3 h-full bg-dark hidden lg:block skew-x-[-12deg] translate-x-20 z-0"
  >
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
      <!-- Text Content -->
      <div class="w-full lg:w-1/2 text-center lg:text-left">
        <div
          class="inline-block px-4 py-1 bg-primary text-dark text-xs font-black uppercase tracking-[0.2em] mb-6"
        >
          La Fortuna · San Carlos · Zona Norte
        </div>

        <h1
          class="font-display text-5xl md:text-7xl font-black text-dark leading-[0.9] uppercase tracking-tighter mb-8"
        >
          Construí tu <br />
          <span class="text-primary italic">Casa Soñada</span><br />
          en La Fortuna
        </h1>

        <p
          class="text-lg md:text-xl text-steel max-w-xl mx-auto lg:mx-0 mb-10 leading-relaxed"
        >
          Diseño y construcción residencial llave en mano en La Fortuna, San Carlos
          y zona norte. Modelos probados, precios transparentes y acompañamiento
          personalizado para que tu proyecto sea una realidad con{" "}
          <span
            class="text-dark font-bold underline decoration-primary decoration-4 underline-offset-4"
            >total tranquilidad</span
          >.
        </p>

        <div
          class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start"
        >
          <a
            href="#disenos"
            class="group relative overflow-hidden bg-dark text-white px-10 py-5 font-black uppercase tracking-widest text-sm transition-all hover:bg-primary hover:text-dark"
          >
            <span
              class="relative z-10 transition-transform group-hover:translate-x-1 inline-block"
              >Ver Modelos &rarr;</span
            >
          </a>

          <a
            href="https://wa.me/50684291847?text=Hola%2C%20me%20interesa%20cotizar%20una%20casa%20en%20La%20Fortuna"
            target="_blank"
            rel="noopener noreferrer"
            class="border-4 border-dark text-dark px-10 py-[1.1rem] font-black uppercase tracking-widest text-sm hover:bg-dark hover:text-white transition-all shadow-xl active:scale-95"
          >
            Escribinos por WhatsApp
          </a>
        </div>
      </div>

      <!-- Image Column -->
      <div class="w-full lg:w-1/2 relative">
        <div class="relative group">
          <!-- Industrial Frame -->
          <div
            class="absolute -inset-4 border-4 border-primary/30 z-0 translate-x-4 translate-y-4 group-hover:translate-x-2 group-hover:translate-y-2 transition-transform"
          >
          </div>

          <Image
            src={heroImg}
            alt="Construcción residencial de calidad en La Fortuna, San Carlos — ConstruHomesCR"
            width={800}
            height={533}
            format="webp"
            quality={85}
            loading="eager"
            fetchpriority="high"
            class="relative z-10 w-full object-cover shadow-2xl grayscale hover:grayscale-0 transition-all duration-700"
          />

          <!-- Floating Badge -->
          <div
            class="absolute -bottom-6 -left-6 bg-primary p-6 shadow-2xl z-20 hidden sm:block"
          >
            <span class="font-display block text-4xl font-black text-dark">15+</span>
            <span
              class="block text-xs font-bold uppercase tracking-widest text-dark/80"
              >Años de Logros</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
