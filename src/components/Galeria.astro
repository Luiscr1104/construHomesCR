---
const images = [
  {
    src: "/images/proyectos/treehouse-cabana-arbol-selva-la-fortuna.webp",
    caption: "Cabaña Árbol",
    alt: "Cabaña árbol construida por ConstruHomesCR rodeada de selva tropical en La Fortuna de San Carlos",
  },
  {
    src: "/images/proyectos/cabana-turistica-dormitorio-jardin-tropical.webp",
    caption: "Cabaña Turística",
    alt: "Dormitorio de cabaña turística Airbnb con vista a jardín tropical en La Fortuna",
  },
  {
    src: "/images/proyectos/jacuzzi-terraza-treehouse-la-fortuna-arenal.webp",
    caption: "Jacuzzi Privado",
    alt: "Jacuzzi privado en terraza de madera con vista a la selva del Arenal en La Fortuna",
  },
  {
    src: "/images/proyectos/casa-madera-exterior-san-carlos-construhomescr.webp",
    caption: "Casa Madera",
    alt: "Exterior de casa de madera con ventanas panorámicas construida por ConstruHomesCR en San Carlos",
  },
  {
    src: "/images/proyectos/casa-moderna-cocina-interior-san-carlos.webp",
    caption: "Casa Moderna",
    alt: "Cocina interior moderna con muebles oscuros y mesones blancos en casa construida en San Carlos",
  },
  {
    src: "/images/proyectos/bano-cabana-ducha-vista-jardin-tropical.webp",
    caption: "Baño Vista Jardín",
    alt: "Baño con ducha de vidrio y vista abierta a jardín tropical en cabaña de La Fortuna",
  },
];
---

<section id="galeria" class="py-24 bg-dark relative">
  <div class="container px-6 mx-auto">
    <div class="max-w-4xl mx-auto text-center mb-20">
      <div
        class="inline-block px-4 py-1 bg-primary text-dark text-[10px] font-black uppercase tracking-[0.3em] mb-4"
      >
        Portafolio
      </div>
      <h2
        class="font-display text-4xl md:text-5xl font-black text-white uppercase tracking-tighter mb-6"
      >
        Proyectos <span class="text-primary italic">Destacados</span>
      </h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Mirá la calidad de ejecución en proyectos reales de la Zona Norte. Cada detalle
        refleja nuestro compromiso con la excelencia técnica.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        images.map(({ src, caption, alt }) => (
          <div class="group relative aspect-square overflow-hidden bg-steel/20 border border-white/5 cursor-pointer">
            <img
              src={src}
              alt={alt}
              width={600}
              height={600}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-700"
            />

            <!-- Overlay -->
            <div class="absolute inset-0 bg-dark/80 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-8">
              <span class="text-primary font-black uppercase text-[10px] tracking-widest mb-2 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                {caption}
              </span>
              <div class="h-1 w-12 bg-primary mb-4 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500 delay-100" />
              <p class="text-white font-bold text-lg leading-tight transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500 delay-200">
                {alt}
              </p>
            </div>

            <!-- Industrial Border -->
            <div class="absolute top-4 left-4 right-4 bottom-4 border border-primary/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none" />
          </div>
        ))
      }
    </div>
  </div>
</section>
