<header
  id="navbar"
  class="fixed top-0 z-50 w-full transition-all duration-300 bg-transparent py-4"
>
  <div class="container mx-auto px-6 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <div
        class="bg-primary p-2 rounded-sm shadow-lg group-hover:scale-105 transition-transform"
      >
        <img
          src="/isotipo.png"
          alt="ConstruHomesCR Logo"
          width="100"
          height="40"
          class="h-8 w-auto"
        />
      </div>
      <span
        class="text-xl font-bold tracking-tighter text-dark hidden sm:block uppercase"
        >Constru<span class="text-primary">Homes</span>CR</span
      >
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:flex items-center gap-8">
      {
        ["Diseños", "Servicios", "Nosotros", "Galería", "Contacto"].map(
          (item) => (
            <a
              href={`/#${item.toLowerCase().replace("í", "i")}`}
              class="text-sm font-bold uppercase tracking-widest text-dark hover:text-primary transition-colors relative group py-2"
            >
              {item}
              <span class="absolute bottom-0 left-0 w-0 h-1 bg-primary transition-all duration-300 group-hover:w-full" />
            </a>
          ),
        )
      }

      <a
        href="https://wa.me/50683196472"
        target="_blank"
        class="bg-dark text-primary px-6 py-2.5 rounded-sm font-bold uppercase text-xs tracking-widest hover:bg-primary hover:text-dark transition-all shadow-md active:scale-95"
      >
        Cotizar Proyecto
      </a>
    </nav>

    <!-- Mobile Button -->
    <button
      id="menu-toggle"
      aria-label="Menu"
      class="md:hidden flex flex-col gap-1.5 p-2"
    >
      <span class="w-6 h-0.5 bg-dark"></span>
      <span class="w-6 h-0.5 bg-dark"></span>
      <span class="w-6 h-0.5 bg-dark"></span>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-dark/95 z-[60] flex flex-col items-center justify-center translate-x-full transition-transform duration-500 ease-in-out md:hidden"
  >
    <button id="close-menu" class="absolute top-8 right-8 text-primary text-4xl"
      >&times;</button
    >
    <nav class="flex flex-col items-center gap-8">
      {
        ["Diseños", "Servicios", "Nosotros", "Galería", "Contacto"].map(
          (item) => (
            <a
              href={`/#${item.toLowerCase().replace("í", "i")}`}
              class="mobile-link text-3xl font-black uppercase text-white hover:text-primary transition-colors"
            >
              {item}
            </a>
          ),
        )
      }
      <a
        href="https://wa.me/50683196472"
        class="mt-8 bg-primary text-dark px-10 py-4 rounded-sm font-black uppercase text-lg shadow-2xl"
      >
        WhatsApp
      </a>
    </nav>
  </div>
</header>

<script>
  const setupNav = () => {
    const navbar = document.getElementById("navbar");
    const menuToggle = document.getElementById("menu-toggle");
    const closeMenu = document.getElementById("close-menu");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    const toggleOpen = () => {
      mobileMenu?.classList.toggle("translate-x-full");
      document.body.style.overflow = mobileMenu?.classList.contains(
        "translate-x-full",
      )
        ? ""
        : "hidden";
    };

    menuToggle?.addEventListener("click", toggleOpen);
    closeMenu?.addEventListener("click", toggleOpen);
    mobileLinks.forEach((link) => link.addEventListener("click", toggleOpen));

    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        navbar?.classList.add("bg-white/95", "shadow-xl", "py-2");
        navbar?.classList.remove("bg-transparent", "py-4");
      } else {
        navbar?.classList.remove("bg-white/95", "shadow-xl", "py-2");
        navbar?.classList.add("bg-transparent", "py-4");
      }
    });
  };

  setupNav();
</script>
