---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ConstruHomesCR - Sitio en Construcción">
	<main class="design-1">
		<div class="container">
			<div class="content">
				<h1>ConstruHomes<span>CR</span></h1>
				<div class="construction-icon">🏗️</div>
				<h2>Sitio en Construcción</h2>
				<p>Estamos trabajando para brindarte la mejor experiencia</p>
				<div class="loader"></div>
				<a href="mailto:ingenieria@construhomescr.com" class="contact-button">
					ingenieria@construhomescr.com
				</a>
			</div>
		</div>
	</main>
</Layout>

<style>
	/* Estilos para Diseño 1 */
	.design-1 {
		background: linear-gradient(135deg, #1a365d 0%, #2d3748 100%);
		color: white;
		display: flex;
		justify-content: center;
		align-items: center;
		min-height: 100vh;
		padding: 3rem 1rem;
		box-sizing: border-box;
		text-align: center;
	}

	.container {
		width: 100%;
		max-width: 600px;
		padding: 2rem;
	}

	.design-1 .content {
		background: rgba(255, 255, 255, 0.1);
		padding: 2rem;
		border-radius: 20px;
		backdrop-filter: blur(10px);
		width: 100%;
		box-sizing: border-box;
	}

	.design-1 h1 {
		font-size: 2rem;
		margin-bottom: 1.5rem;
	}

	.design-1 h1 span {
		color: #f6ad55;
	}

	.design-1 .construction-icon {
		font-size: 3rem;
		margin: 1.5rem 0;
	}

	.design-1 .loader {
		width: 50px;
		height: 50px;
		border: 5px solid #f3f3f3;
		border-top: 5px solid #f6ad55;
		border-radius: 50%;
		margin: 1.5rem auto;
		animation: spin 1s linear infinite;
	}

	.design-1 .contact-button {
		display: inline-block;
		padding: 1rem;
		background: #f6ad55;
		color: #1a365d;
		text-decoration: none;
		border-radius: 30px;
		font-weight: 600;
		margin-top: 1.5rem;
		transition: transform 0.3s ease;
		word-break: break-word;
		max-width: 90%;
	}

	.design-1 .contact-button:hover {
		transform: translateY(-2px);
	}

	@keyframes spin {
		0% { transform: rotate(0deg); }
		100% { transform: rotate(360deg); }
	}

	/* Responsividad */
	@media (max-width: 768px) {
		.design-1 {
			padding: 2rem 1rem;
		}
		.design-1 h1 {
			font-size: 1.8rem;
		}
		.design-1 .construction-icon {
			font-size: 2.5rem;
		}
	}

	@media (max-width: 480px) {
		.design-1 {
			padding: 1.5rem 1rem;
		}
		.design-1 h1 {
			font-size: 1.5rem;
		}
		.design-1 .construction-icon {
			font-size: 2rem;
		}
		.design-1 .contact-button {
			font-size: 0.9rem;
			padding: 0.8rem;
			max-width: 100%;
		}
	}
</style>