---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const categoryLabels: Record<string, string> = {
  costos: 'Costos',
  permisos: 'Permisos',
  inversion: 'Inversión',
  modelos: 'Modelos',
  zona: 'Zona Norte',
  guias: 'Guías',
};

const categories = [...new Set(posts.map((p) => p.data.category))];
---

<Layout
  title="Blog ConstruHomesCR | Guías de construcción en La Fortuna"
  description="Guías, costos, permisos e inversión turística para construir en La Fortuna y zona norte de Costa Rica. Todo lo que necesitás saber antes de construir."
  canonical="https://construhomescr.com/blog/"
>
  <div class="pt-28 pb-32 bg-white">
    <!-- Hero del blog -->
    <div class="bg-dark py-20 mb-16">
      <div class="container mx-auto px-6 text-center max-w-3xl">
        <div class="inline-block px-4 py-1 bg-primary text-dark text-[10px] font-black uppercase tracking-[0.3em] mb-6">
          Blog
        </div>
        <h1 class="font-display text-4xl md:text-5xl font-black text-white uppercase tracking-tighter mb-6">
          Guías para Construir en <span class="text-primary">La Fortuna</span>
        </h1>
        <p class="text-gray-400 text-lg leading-relaxed">
          Costos reales, permisos, inversión Airbnb y todo lo que necesitás saber antes de construir en zona norte de Costa Rica.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-6 max-w-6xl">
      <!-- Posts grid -->
      {categories.map((cat) => {
        const catPosts = posts.filter((p) => p.data.category === cat);
        if (catPosts.length === 0) return null;
        return (
          <div class="mb-20">
            <div class="flex items-center gap-4 mb-10">
              <span class="inline-block px-4 py-1 bg-dark text-primary text-[10px] font-black uppercase tracking-[0.3em]">
                {categoryLabels[cat] ?? cat}
              </span>
              <div class="h-px flex-1 bg-gray-100" />
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
              {catPosts.map((post) => {
                const slug = post.id.replace(/\.mdx$/, '');
                return (
                  <a
                    href={`/blog/${slug}/`}
                    class="group border border-gray-100 hover:border-primary/40 hover:shadow-xl transition-all"
                  >
                    <div class="overflow-hidden">
                      <Image
                        src={post.data.heroImage}
                        alt={post.data.heroImageAlt}
                        width={600}
                        height={340}
                        format="webp"
                        quality={78}
                        loading="lazy"
                        class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-700"
                      />
                    </div>
                    <div class="p-6">
                      <time
                        datetime={post.data.pubDate.toISOString()}
                        class="text-[10px] font-bold uppercase tracking-widest text-steel"
                      >
                        {post.data.pubDate.toLocaleDateString('es-CR', {
                          year: 'numeric',
                          month: 'short',
                          day: 'numeric',
                        })}
                      </time>
                      <h2 class="font-display text-xl font-black text-dark uppercase tracking-tighter mt-2 mb-3 leading-snug group-hover:text-primary transition-colors line-clamp-2">
                        {post.data.title}
                      </h2>
                      <p class="text-steel text-sm leading-relaxed line-clamp-3">
                        {post.data.description}
                      </p>
                      <div class="mt-5 flex items-center gap-2 text-xs font-black uppercase tracking-widest text-primary">
                        <span>Leer más</span>
                        <span>&rarr;</span>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}

      {posts.length === 0 && (
        <div class="text-center py-20 text-steel">
          <p class="text-lg">Próximamente — los primeros artículos están en camino.</p>
        </div>
      )}
    </div>
  </div>
</Layout>
