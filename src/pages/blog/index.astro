---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const categoryLabels: Record<string, string> = {
  costos: 'Costos',
  permisos: 'Permisos',
  inversion: 'Inversión',
  modelos: 'Modelos',
  zona: 'Zona Norte',
  guias: 'Guías',
};

const categories = [...new Set(posts.map((p) => p.data.category))];

const readingTime = (body: string): number => {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
};

const postsWithTime = posts.map((p) => ({
  ...p,
  readTime: readingTime(p.body ?? ''),
}));
---

<Layout
  title="Blog ConstruHomesCR | Guías de construcción en La Fortuna"
  description="Guías, costos, permisos e inversión turística para construir en La Fortuna y zona norte de Costa Rica. Todo lo que necesitás saber antes de construir."
  canonical="https://construhomescr.com/blog/"
>
  <div class="pt-28 pb-32 bg-white">
    <!-- Hero del blog -->
    <div class="bg-dark py-20 mb-16">
      <div class="container mx-auto px-6 text-center max-w-3xl">
        <div class="inline-block px-4 py-1 bg-primary text-dark text-[10px] font-black uppercase tracking-[0.3em] mb-6">
          Blog
        </div>
        <h1 class="font-display text-4xl md:text-5xl font-black text-white uppercase tracking-tighter mb-6">
          Guías para Construir en <span class="text-primary">La Fortuna</span>
        </h1>
        <p class="text-gray-400 text-lg leading-relaxed">
          Costos reales, permisos, inversión Airbnb y todo lo que necesitás saber antes de construir en zona norte de Costa Rica.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-6 max-w-6xl">
      <!-- Posts grid -->
      {categories.map((cat) => {
        const catPosts = postsWithTime.filter((p) => p.data.category === cat);
        if (catPosts.length === 0) return null;
        return (
          <div class="mb-20">
            <div class="flex items-center gap-4 mb-10">
              <span class="inline-block px-4 py-1 bg-dark text-primary text-[10px] font-black uppercase tracking-[0.3em]">
                {categoryLabels[cat] ?? cat}
              </span>
              <div class="h-px flex-1 bg-gray-100" />
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
              {catPosts.map((post) => {
                const slug = post.id.replace(/\.mdx$/, '');
                return (
                  <a
                    href={`/blog/${slug}/`}
                    class="group border border-gray-100 hover:border-primary/40 hover:shadow-xl transition-all"
                  >
                    <div class="overflow-hidden">
                      <Image
                        src={post.data.heroImage}
                        alt={post.data.heroImageAlt}
                        width={600}
                        height={340}
                        format="webp"
                        quality={78}
                        loading="lazy"
                        class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-700"
                      />
                    </div>
                    <div class="p-6">
                      <div class="flex items-center gap-3 mt-1 mb-2">
                        <time
                          datetime={post.data.pubDate.toISOString()}
                          class="text-[10px] font-bold uppercase tracking-widest text-steel"
                        >
                          {post.data.pubDate.toLocaleDateString('es-CR', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric',
                          })}
                        </time>
                        <span class="text-steel/40 text-[10px]">·</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-steel">
                          {post.readTime} min lectura
                        </span>
                      </div>
                      <h2 class="font-display text-xl font-black text-dark uppercase tracking-tighter mt-2 mb-3 leading-snug group-hover:text-primary transition-colors line-clamp-2">
                        {post.data.title}
                      </h2>
                      <p class="text-steel text-sm leading-relaxed line-clamp-3">
                        {post.data.description}
                      </p>
                      <div class="mt-5 flex items-center gap-2 text-xs font-black uppercase tracking-widest text-primary">
                        <span>Leer más</span>
                        <span>&rarr;</span>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}

      {posts.length === 0 && (
        <div class="text-center py-20 text-steel">
          <p class="text-lg">Próximamente — los primeros artículos están en camino.</p>
        </div>
      )}

      <!-- CTA de conversión -->
      <div class="mt-8 bg-dark p-12 text-center border-b-4 border-primary">
        <div class="inline-block px-4 py-1 bg-primary text-dark text-[10px] font-black uppercase tracking-[0.3em] mb-6">
          ¿Listo para construir?
        </div>
        <p class="font-display text-3xl md:text-4xl font-black text-white uppercase tracking-tighter mb-4">
          Tu proyecto empieza<br />
          <span class="text-primary italic">con una consulta gratis</span>
        </p>
        <p class="text-gray-400 mb-8 max-w-xl mx-auto leading-relaxed">
          Leíste cómo funciona — ahora hablemos de tu terreno, tu presupuesto y tu plazo. Sin compromiso.
        </p>
        <a
          href="https://wa.me/50660290126?text=Hola%2C+vi+el+blog+de+ConstruHomesCR+y+quiero+cotizar+mi+proyecto"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-primary text-dark font-black uppercase tracking-widest text-sm px-10 py-5 hover:bg-white transition-all shadow-xl active:scale-95"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Cotizá tu proyecto gratis &rarr;
        </a>
      </div>
    </div>
  </div>
</Layout>
