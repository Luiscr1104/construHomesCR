---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Página no encontrada | ConstruHomesCR"
  description="Esta página no existe. Volvé al inicio de ConstruHomesCR."
>
  <section class="min-h-screen flex items-center justify-center bg-white pt-20">
    <div class="container mx-auto px-6 text-center max-w-2xl">
      <div class="inline-block px-4 py-1 bg-primary text-dark text-[10px] font-black uppercase tracking-[0.2em] mb-6">
        Error 404
      </div>
      <h1 class="text-7xl md:text-9xl font-black text-dark uppercase tracking-tighter leading-none mb-6">
        404
      </h1>
      <p class="text-xl text-steel mb-10 leading-relaxed">
        Esta página no existe — pero tu casa soñada en La Fortuna sí puede ser realidad.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="bg-dark text-white px-10 py-5 font-black uppercase tracking-widest text-sm hover:bg-primary hover:text-dark transition-all"
        >
          Volvé al inicio &rarr;
        </a>
        <a
          href="https://wa.me/50684291847"
          target="_blank"
          rel="noopener noreferrer"
          class="border-4 border-dark text-dark px-10 py-[1.1rem] font-black uppercase tracking-widest text-sm hover:bg-dark hover:text-white transition-all"
        >
          Escribinos por WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
