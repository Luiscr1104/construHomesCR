---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <title>ConstruHomesCR | Construcción Residencial en La Fortuna, San Carlos</title>
    <meta
      name="description"
      content="Construí tu casa en La Fortuna de San Carlos y zona norte de Costa Rica. Modelos residenciales de calidad, precios transparentes y acompañamiento personalizado. Cotizá hoy."
    />
    <meta
      name="keywords"
      content="construcción La Fortuna, casas San Carlos, constructora zona norte Costa Rica, vivienda La Fortuna, casas prefabricadas San Carlos, construir casa La Fortuna"
    />
    <link rel="canonical" href="https://construhomescr.com/" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://construhomescr.com/" />
    <meta
      property="og:title"
      content="ConstruHomesCR | Construcción Residencial en La Fortuna, San Carlos"
    />
    <meta
      property="og:description"
      content="Construí tu casa en La Fortuna de San Carlos y zona norte de Costa Rica. Modelos probados, precios transparentes. Cotizá sin compromiso."
    />
    <meta property="og:image" content="/img.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://construhomescr.com/" />
    <meta
      property="twitter:title"
      content="ConstruHomesCR | Construcción Residencial en La Fortuna, San Carlos"
    />
    <meta
      property="twitter:description"
      content="Construí tu casa en La Fortuna de San Carlos y zona norte de Costa Rica. Modelos probados, precios transparentes. Cotizá sin compromiso."
    />
    <meta property="twitter:image" content="/img.jpg" />
  </head>
  <body class="bg-white text-text antialiased">
    <div
      class="fixed inset-0 h-full w-full z-[-1] opacity-[0.03] pointer-events-none
      bg-[linear-gradient(to_right,#1a1a1a_1px,transparent_1px),linear-gradient(to_bottom,#1a1a1a_1px,transparent_1px)]
      bg-[size:40px_40px]"
    >
    </div>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
