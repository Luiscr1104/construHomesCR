---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyContactBar from "../components/StickyContactBar.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const SITE = "https://construhomescr.com";
const DEFAULT_TITLE = "ConstruHomesCR | Construcción Residencial en La Fortuna, San Carlos";
const DEFAULT_DESC = "Construí tu casa en La Fortuna de San Carlos. Modelos llave en mano, precios transparentes y acompañamiento total. Cotizá gratis por WhatsApp.";

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESC,
  image = `${SITE}/og-default.jpg`,
  canonical = `${SITE}${Astro.url.pathname}`,
} = Astro.props;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "GeneralContractor",
      "@id": `${SITE}/#contractor`,
      name: "ConstruHomesCR",
      url: SITE,
      logo: `${SITE}/isotipo.png`,
      image: [
        `${SITE}/og-default.jpg`,
        `${SITE}/images/Curri.jpeg`,
        `${SITE}/images/Trapiche.jpeg`,
        `${SITE}/images/Libelula.jpeg`,
      ],
      description: DEFAULT_DESC,
      telephone: "+50684291847",
      email: "info@construhomescr.com",
      priceRange: "$$",
      currenciesAccepted: "CRC, USD",
      paymentAccepted: "Cash, Bank Transfer",
      knowsLanguage: ["es", "en"],
      hasMap: "https://www.google.com/maps/place/ConstruHomesCR/@10.4699403,-84.6403884,4275m/data=!3m2!1e3!4b1!4m6!3m5!1s0x6f63c6638f5d65c3:0xa56b007e0259247b!8m2!3d10.4699402!4d-84.6403884!16s%2Fg%2F11njxhqrjw",
      areaServed: [
        { "@type": "City", name: "La Fortuna" },
        { "@type": "AdministrativeArea", name: "San Carlos" },
        { "@type": "AdministrativeArea", name: "Zona Norte, Costa Rica" },
      ],
      address: {
        "@type": "PostalAddress",
        addressLocality: "La Fortuna",
        addressRegion: "San Carlos, Alajuela",
        addressCountry: "CR",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 10.4707,
        longitude: -84.6431,
      },
      openingHoursSpecification: [
        {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          opens: "09:00",
          closes: "18:00",
        },
      ],
      sameAs: [
        "https://www.instagram.com/construhomescr",
        "https://www.facebook.com/construhomescr",
      ],
    },
    {
      "@type": "Service",
      "@id": `${SITE}/#service-llave-en-mano`,
      name: "Construcción residencial llave en mano",
      serviceType: "Construcción residencial",
      provider: { "@id": `${SITE}/#contractor` },
      areaServed: { "@type": "AdministrativeArea", name: "Zona Norte, Costa Rica" },
    },
    {
      "@type": "Service",
      "@id": `${SITE}/#service-diseno`,
      name: "Diseño arquitectónico",
      serviceType: "Diseño y planificación",
      provider: { "@id": `${SITE}/#contractor` },
      areaServed: { "@type": "AdministrativeArea", name: "Zona Norte, Costa Rica" },
    },
    {
      "@type": "Service",
      "@id": `${SITE}/#service-cabanas`,
      name: "Cabañas turísticas para Airbnb",
      serviceType: "Construcción turística",
      provider: { "@id": `${SITE}/#contractor` },
      areaServed: { "@type": "City", name: "La Fortuna" },
    },
    {
      "@type": "Service",
      "@id": `${SITE}/#service-permisos`,
      name: "Gestión de permisos municipales e INVU",
      serviceType: "Trámites y permisos de construcción",
      provider: { "@id": `${SITE}/#contractor` },
      areaServed: { "@type": "AdministrativeArea", name: "San Carlos" },
    },
    {
      "@type": "Service",
      "@id": `${SITE}/#service-ict`,
      name: "Acompañamiento ICT y declaratoria turística",
      serviceType: "Consultoría turística",
      provider: { "@id": `${SITE}/#contractor` },
      areaServed: { "@type": "City", name: "La Fortuna" },
    },
    {
      "@type": "WebSite",
      "@id": `${SITE}/#website`,
      url: SITE,
      name: "ConstruHomesCR",
      publisher: { "@id": `${SITE}/#contractor` },
      inLanguage: "es-CR",
    },
  ],
};
---

<!doctype html>
<html lang="es-CR">
  <head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NMBZX2X6');</script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preconnect para Google Fonts (performance) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Archivo Black (headings) + Inter (body) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Icons / PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#fdb813" />

    <!-- SEO primario -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="ConstruHomesCR" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta
      name="keywords"
      content="construcción La Fortuna, casas San Carlos, constructora zona norte Costa Rica, vivienda La Fortuna, vivienda llave en mano San Carlos, construir casa La Fortuna"
    />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ConstruHomesCR — Construcción residencial en La Fortuna" />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:site_name" content="ConstruHomesCR" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  </head>
  <body class="bg-white text-text antialiased pb-20">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NMBZX2X6"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <div
      class="fixed inset-0 h-full w-full z-[-1] opacity-[0.03] pointer-events-none
      bg-[linear-gradient(to_right,#1a1a1a_1px,transparent_1px),linear-gradient(to_bottom,#1a1a1a_1px,transparent_1px)]
      bg-[size:40px_40px]"
    >
    </div>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <StickyContactBar />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
