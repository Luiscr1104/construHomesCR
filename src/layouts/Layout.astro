---
import "../styles/global.css";
import Header from "../components/Header.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="description"
      content="ConstruHomesCR - Diseño, consultoría y construcción de proyectos residenciales y comerciales en Costa Rica."
    />
    <title>ConstruHomesCR | Construcción y Diseño</title>
  </head>
  <body class="bg-white text-text antialiased">
    <div
      class="fixed inset-0 h-full w-full z-[-1] opacity-[0.03] pointer-events-none
      bg-[linear-gradient(to_right,#1a1a1a_1px,transparent_1px),linear-gradient(to_bottom,#1a1a1a_1px,transparent_1px)]
      bg-[size:40px_40px]"
    >
    </div>

    <Header />
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
