---
import "../styles/global.css";
import Header from "../components/Header.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <title>ConstruHomesCR | Construcción y Diseño en Costa Rica</title>
    <meta
      name="description"
      content="Diseño, consultoría y construcción de proyectos residenciales y comerciales con los más altos estándares de calidad en Costa Rica. Especialistas en arquitectura de alta precisión."
    />
    <meta
      name="keywords"
      content="construcción, diseño, arquitectura, Costa Rica, San Carlos, La Fortuna, residencial, comercial, ingeniería"
    />
    <link rel="canonical" href="https://construhomescr.com/" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://construhomescr.com/" />
    <meta
      property="og:title"
      content="ConstruHomesCR | Construcción y Diseño Profesional"
    />
    <meta
      property="og:description"
      content="Transformamos su visión en estructuras sólidas con estándares superiores de calidad y diseño."
    />
    <meta property="og:image" content="/img.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://construhomescr.com/" />
    <meta
      property="twitter:title"
      content="ConstruHomesCR | Construcción y Diseño Profesional"
    />
    <meta
      property="twitter:description"
      content="Transformamos su visión en estructuras sólidas con estándares superiores de calidad y diseño."
    />
    <meta property="twitter:image" content="/img.jpg" />
  </head>
  <body class="bg-white text-text antialiased">
    <div
      class="fixed inset-0 h-full w-full z-[-1] opacity-[0.03] pointer-events-none
      bg-[linear-gradient(to_right,#1a1a1a_1px,transparent_1px),linear-gradient(to_bottom,#1a1a1a_1px,transparent_1px)]
      bg-[size:40px_40px]"
    >
    </div>

    <Header />
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
